---
interface Props {
	id: string,
	sup?: boolean,
	__xref__?: string,
}
const { id, sup = false, __xref__ } = Astro.props;
if(__xref__ === undefined)
	throw new TypeError('Ref: missing __xref__');
---

{
	sup
		? <sup><a id={`xref:${id}:${__xref__}`} class="show-decoration text-ref" href={`#ref:${id}`} aria-label={`참고 문헌 ${id}`}>[{id}]</a></sup>
		: <a id={`xref:${id}:${__xref__}`} class="hide-decoration text-ref" href={`#ref:${id}`} aria-label={`참고 문헌 ${id}`}>[{id}]</a>
}